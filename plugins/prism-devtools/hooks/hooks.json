{
  "_comment": "Plugin hooks bridge Claude Code lifecycle events to the PRISM MCP server (Brain, Janitor, Memory). Workflow orchestration (phase advancement, story gates, agent dispatch) lives in the MCP server, not here.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/session-start.py",
            "description": "Bootstrap Brain, seed auto-memory pointer, run incremental reindex"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/pre-read-token-guard.py",
            "description": "Track file reads and warn on redundant re-reads with token estimates"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/pre-write-convention-guard.py",
            "description": "Check proposed writes against known conventions from Memory"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/capture-commit-context.py",
            "description": "Capture git commit context into Brain on commit"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/capture-file-context.py",
            "description": "Trigger Brain incremental reindex on file edits (30s debounce)"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/save-large-responses.py",
            "description": "Save large tool responses (>50 lines) to files to reduce context bloat"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/log-terminal-output.py",
            "description": "Log terminal command outputs to files for later grep searching"
          }
        ]
      },
      {
        "matcher": "mcp__prism__brain_search|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/feedback_signal_hook.py",
            "description": "Implicit retrieval feedback: correlate brain_search results with Read/Edit to emit auto thumbs-up via brain_search_feedback MCP"
          }
        ]
      }
    ]
  }
}
