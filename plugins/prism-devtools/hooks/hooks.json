{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/session-start.py",
            "description": "Bootstrap Brain, seed auto-memory pointer, run incremental reindex"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/enforce-story-context.py",
            "description": "Ensure workflow commands have required story context"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/pre-read-token-guard.py",
            "description": "Track file reads and warn on redundant re-reads with token estimates"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/pre-write-convention-guard.py",
            "description": "Check proposed writes against known conventions from Memory"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/prism_activity_hook.py",
            "description": "Update dashboard with real-time activity"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/track-current-story.py",
            "description": "Track story file as current workflow context"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/validate-story-updates.py",
            "description": "Validate story file updates"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/validate-required-sections.py",
            "description": "Verify all required PRISM sections exist"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/capture-commit-context.py",
            "description": "Capture git commit context into Brain on commit"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/capture-file-context.py",
            "description": "Trigger Brain incremental reindex on file edits (30s debounce)"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/save-large-responses.py",
            "description": "Save large tool responses (>50 lines) to files to reduce context bloat"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/log-terminal-output.py",
            "description": "Log terminal command outputs to files for later grep searching"
          }
        ]
      },
      {
        "matcher": "mcp__prism__brain_search|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/feedback_signal_hook.py",
            "description": "Implicit retrieval feedback: correlate brain_search results with Read/Edit to emit auto thumbs-up via brain_search_feedback MCP"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/subagent_sfr_inject.py",
            "description": "Inject SFR certificate template + Brain context into sub-agent"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/subagent_stop_recorder.py",
            "description": "Record sub-agent outcome for SFR scoring and observability"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/prism_stop_hook.py",
            "description": "Auto-advance PRISM workflow on response completion",
            "timeout": 120000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${PRISM_DEVTOOLS_ROOT}/hooks/consolidate-story-learnings.py",
            "description": "Consolidate completed story learnings into Mulch"
          }
        ]
      }
    ]
  }
}
